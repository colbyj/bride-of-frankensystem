        <mxCell id="FLXTgydPradgtQ5n2XYN-68" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EFF4FC;strokeColor=#8FC0FF;glass=0;align=left;fontSize=12;fontColor=default;fontFamily=Lato,proxima-nova,Helvetica Neue,Arial,sans-serif;verticalAlign=middle;absoluteArcSize=0;arcSize=12;fixDash=0;dropTarget=0;" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;Show the consent form (defined in &lt;font style=&quot;color: rgb(153, 0, 0);&quot; face=&quot;Lucida Console&quot;&gt;/consent.html&lt;/font&gt;), create a participant entry in database upon consent. Use as the first page in the list.&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(51, 51, 51), rgb(171, 171, 171));&quot;&gt;Path: &lt;/font&gt;&lt;/span&gt;&lt;font face=&quot;Lucida Console&quot; style=&quot;background-color: transparent; color: rgb(153, 0, 0);&quot;&gt;consent&lt;/font&gt;&lt;/div&gt;" vertex="1">
