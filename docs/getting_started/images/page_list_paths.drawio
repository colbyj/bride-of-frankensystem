        <UserObject label="Questionnaires" id="FLXTgydPradgtQ5n2XYN-18">
          <mxCell parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Lato,proxima-nova,Helvetica Neue,Arial,sans-serif;fontSize=14;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1">
