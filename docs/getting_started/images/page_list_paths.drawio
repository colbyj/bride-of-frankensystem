        <mxCell id="FLXTgydPradgtQ5n2XYN-19" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Lato,proxima-nova,Helvetica Neue,Arial,sans-serif;fontSize=14;fillColor=#d5e8d4;strokeColor=#82b366;" value="Instruction Pages" vertex="1">
          <mxGeometry height="30" width="130" x="270" y="660" as="geometry" />
        </mxCell>
        <mxCell id="FLXTgydPradgtQ5n2XYN-25" parent="1" style="rounded=0;whiteSpace=wrap;html=1;glass=0;align=left;fontSize=12;fontFamily=Lato,proxima-nova,Helvetica Neue,Arial,sans-serif;fillColor=#EFF4FC;strokeColor=#8FC0FF;shadow=0;" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;Defined using JSON. Files placed in &lt;font face=&quot;Lucida Console&quot; style=&quot;color: rgb(153, 0, 0);&quot;&gt;/questionnaires/&amp;lt;questionnaireName&amp;gt;.json&lt;/font&gt;&lt;div style=&quot;margin-top: 4px;&quot;&gt;Choose from pre-made question types or make your own via HTML templates.&lt;/div&gt;&lt;div style=&quot;margin-top: 4px;&quot;&gt;Path: &lt;font style=&quot;color: rgb(153, 0, 0);&quot; face=&quot;Lucida Console&quot;&gt;questionnaires/&amp;lt;name&amp;gt;/&amp;lt;tag&amp;gt;&lt;/font&gt;&lt;font&gt; &lt;font face=&quot;Tahoma&quot; style=&quot;color: rgb(0, 0, 0);&quot;&gt;(&lt;/font&gt;&lt;font face=&quot;Lucida Console&quot; style=&quot;color: light-dark(rgb(153, 0, 0), rgb(255, 181, 181));&quot;&gt;/&amp;lt;tag&amp;gt;&lt;/font&gt;&lt;/font&gt;&amp;nbsp;is optional, use if using the same questionnaire twice)&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="437.5" x="440" y="580" as="geometry" />
        </mxCell>
        <mxCell id="FLXTgydPradgtQ5n2XYN-32" parent="1" style="rounded=0;whiteSpace=wrap;glass=0;align=left;fontSize=12;html=1;fontFamily=Lato,proxima-nova,Helvetica Neue,Arial,sans-serif;verticalAlign=middle;fillColor=#EFF4FC;strokeColor=#8FC0FF;fontColor=default;shadow=0;" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;font&gt;Defined using HTML. Files placed in&lt;br&gt;&lt;font face=&quot;Lucida Console&quot; style=&quot;color: rgb(153, 0, 0);&quot;&gt;/templates/instructions/&amp;lt;page&amp;gt;.html&lt;/font&gt;, &lt;font face=&quot;Lucida Console&quot; style=&quot;color: rgb(153, 0, 0);&quot;&gt;/templates/simple/&amp;lt;page&amp;gt;.html&lt;/font&gt;, or &lt;font face=&quot;Lucida Console&quot; style=&quot;color: rgb(153, 0, 0);&quot;&gt;/templates/custom/&amp;lt;page&amp;gt;.html&lt;/font&gt;,&amp;nbsp;&lt;br&gt;&lt;/font&gt;&lt;div&gt;&lt;div style=&quot;margin-top: 4px;&quot;&gt;&lt;font&gt;Can optionally use template scripting (Jinja) to display user data or conditionally affect what shows on the page. Instruction pages show a &quot;continue&quot; button; custom pages show no theming.&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;margin-top: 4px;&quot;&gt;&lt;font&gt;Display-only by default. Use JavaScript to send data to &quot;tables&quot; (e.g., to collect task-related data).&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;margin-top: 4px;&quot;&gt;&lt;font&gt;Path: &lt;font face=&quot;Lucida Console&quot; style=&quot;color: rgb(153, 0, 0);&quot;&gt;instructions/&amp;lt;page&amp;gt;&lt;/font&gt;, &lt;font style=&quot;color: rgb(153, 0, 0);&quot; face=&quot;Lucida Console&quot;&gt;simple/&amp;lt;page&amp;gt;&lt;/font&gt;, or &lt;font style=&quot;color: rgb(153, 0, 0);&quot; face=&quot;Lucida Console&quot;&gt;custom/&amp;lt;page&amp;gt;&lt;/font&gt;.&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="437.5" x="440" y="690" as="geometry" />
        </mxCell>
