          </mxGeometry>
        </mxCell>
        <mxCell id="xSClNSHaVlQnWdRqsnNF-33" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=4;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="To add additional pages, add HTML files to one of these directories.&amp;nbsp;&lt;div style=&quot;margin-top: 8px;&quot;&gt;&quot;Instruction&quot; pages display your HTML with BOFS chrome and display a &quot;continue&quot; button.&lt;/div&gt;&lt;div style=&quot;margin-top: 8px;&quot;&gt;&quot;Simple&quot; pages&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;pages display your HTML with BOFS chrome, but without a &quot;continue&quot; button.&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;margin-top: 8px;&quot;&gt;&quot;Custom&quot; pages&amp;nbsp;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;pages display your HTML without BOFS chrome, and without a &quot;continue&quot; button.&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="165.66" width="280" x="480" y="474.34" as="geometry" />
        </mxCell>
        <mxCell id="xSClNSHaVlQnWdRqsnNF-35" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=4;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="To add static assets (images, videos, audio clips, JavaScript), add them to the &lt;font face=&quot;Lucida Console&quot; style=&quot;color: rgb(153, 0, 0);&quot;&gt;static/&lt;/font&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;directory.&lt;/span&gt;&lt;div style=&quot;margin-top: 8px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;These can be referenced from any template or questionnaire at the &lt;font face=&quot;Lucida Console&quot; style=&quot;color: light-dark(rgb(153, 0, 0), rgb(255, 255, 255));&quot;&gt;/static/&amp;lt;filename&amp;gt;&lt;/font&gt; URL.&lt;/span&gt;&lt;/div&gt;" vertex="1">
