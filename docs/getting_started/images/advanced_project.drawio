        <mxCell id="xSClNSHaVlQnWdRqsnNF-31" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=4;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="To store additional data (e.g., for an experimental task), you can define database tables using JSON.&lt;div style=&quot;margin-top: 8px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Each table is one JSON file.&amp;nbsp;&lt;/span&gt;&lt;div&gt;&lt;div style=&quot;margin-top: 8px; margin-right: 0px;&quot;&gt;You can POST data to your table via &lt;font style=&quot;color: rgb(153, 0, 0);&quot; face=&quot;Lucida Console&quot;&gt;/table/&amp;lt;name&amp;gt;&lt;/font&gt;, data gets automatically timestamped and associated with the participant.&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="280" x="480" y="344.34000000000003" as="geometry" />
        </mxCell>
